# Set to true to skip Infisical and read SMTP config from DEV_SMTP_* vars below
DEV_MODE=false

# App
SERVER_PORT=6969

# Temporal
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default

# Infisical credentials (required when DEV_MODE=false)
INFISICAL_ADDR=https://vault.example.com
INFISICAL_PROJECT_ID=<project-id>
INFISICAL_ENVIRONMENT=dev
# Machine Identity (preferred):
INFISICAL_CLIENT_ID=<client-id>
INFISICAL_CLIENT_SECRET=<client-secret>
# Legacy alternative:
# INFISICAL_API_KEY=<api-key>

# How often (in seconds) the config watcher re-fetches SMTP config from
# Infisical. Defaults to 300 (5 minutes) if unset.
# CONFIG_POLL_INTERVAL=300

# Bearer token required for POST /admin/config/refresh.
# Leave unset to disable that endpoint (returns 403).
# ADMIN_TOKEN=<change-me-use-a-strong-random-value>

# Worker only: which SMTP provider this worker instance serves.
# PROVIDER_NAME=sendgrid

# Dev SMTP config (required when DEV_MODE=true)
DEV_SMTP_NAME=dev
DEV_SMTP_HOST=smtp.example.com
DEV_SMTP_PORT=587
DEV_SMTP_USERNAME=user@example.com
DEV_SMTP_PASSWORD=secret
DEV_SMTP_AUTH_TYPE=PLAIN
# DEV_SMTP_PROVIDER=dev   # defaults to DEV_SMTP_NAME if omitted
# DEV_SMTP_FROM=noreply@example.com   # defaults to DEV_SMTP_USERNAME if omitted
# DEV_SMTP_FROM_NAME=Beacon           # defaults to "Beacon" if omitted
