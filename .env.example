# Beacon — environment variable template
# Copy this file to .env and fill in the values.
# WARNING: all variables below are commented out by default — uncomment and fill
# in only what your environment needs. DEV_MODE in particular must not be set
# to true in production.

# ── Core ─────────────────────────────────────────────────────────────────────
SERVER_PORT=6969
# CONFIG_POLL_INTERVAL=300    # seconds between Infisical config refreshes
# ADMIN_TOKEN=                # required for POST /admin/config/refresh

# ── Temporal ─────────────────────────────────────────────────────────────────
# TEMPORAL_ADDRESS=localhost:7233
# TEMPORAL_NAMESPACE=default

# ── Infisical (production SMTP config) ───────────────────────────────────────
# INFISICAL_ADDR=
# INFISICAL_PROJECT_ID=
# INFISICAL_ENVIRONMENT=prod
# INFISICAL_CLIENT_ID=
# INFISICAL_CLIENT_SECRET=

# ── Dev mode — set DEV_MODE=true to skip Infisical and use vars below ────────
# DEV_MODE=true
# DEV_SMTP_HOST=smtp.example.com
# DEV_SMTP_PORT=587
# DEV_SMTP_USERNAME=
# DEV_SMTP_PASSWORD=
# DEV_SMTP_AUTH_TYPE=PLAIN
