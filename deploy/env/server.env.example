# ---------------------------------------------------------------------------
# Beacon HTTP Server — environment variable template
#
# Copy this file to server.env and fill in real values.
# DO NOT commit server.env to version control.
# ---------------------------------------------------------------------------

# --- Core -------------------------------------------------------------------

# HTTP port the server listens on. Matches the Docker / systemd port mapping.
SERVER_PORT=6969

# Set to "false" in production. When "true", Infisical is skipped and
# DEV_SMTP_* vars below are used instead.
DEV_MODE=false

# --- Temporal ---------------------------------------------------------------

# Temporal server gRPC address. In docker-compose this is temporal:7233.
# For a managed Temporal Cloud instance use: <namespace>.tmprl.cloud:7233
TEMPORAL_ADDRESS=temporal:7233

# Temporal namespace (must exist before starting Beacon).
TEMPORAL_NAMESPACE=default

# --- Infisical (production secret store) ------------------------------------

# URL of your Infisical instance (SaaS: https://app.infisical.com).
INFISICAL_ADDR=https://app.infisical.com

# Project ID shown in Infisical project settings.
INFISICAL_PROJECT_ID=<your-project-id>

# Infisical environment slug (e.g. dev, staging, prod).
INFISICAL_ENVIRONMENT=prod

# Machine identity credentials for Beacon to authenticate with Infisical.
INFISICAL_CLIENT_ID=<your-client-id>
INFISICAL_CLIENT_SECRET=<your-client-secret>

# --- Admin API --------------------------------------------------------------

# Bearer token required for admin endpoints (e.g. /dlq/*).
# Leave unset to disable all admin endpoints.
ADMIN_TOKEN=<change-me-use-a-strong-random-value>

# --- Config polling ---------------------------------------------------------

# How often (in seconds) the config watcher re-fetches SMTP config from
# Infisical. Defaults to 300 (5 minutes) if unset.
CONFIG_POLL_INTERVAL=300
