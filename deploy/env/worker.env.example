# ---------------------------------------------------------------------------
# Beacon Email Worker — environment variable template
#
# Copy this file to worker.env and fill in real values.
# DO NOT commit worker.env to version control.
#
# WORKER_SPEC is intentionally omitted here — it is set per-instance:
#   - docker-compose: set it in the service's `environment:` block.
#   - systemd:        set via the template unit's Environment=WORKER_SPEC=%i
#                     (the instance name, e.g. beacon-worker@email-sendgrid.service).
# ---------------------------------------------------------------------------

# --- Channel + provider (set per-instance, not here) -------------------------
# Uncomment and set if you are NOT using the docker-compose / systemd
# per-instance mechanism described above.
# WORKER_SPEC=email-sendgrid  # or set CHANNEL / PROVIDER_NAME separately

# --- Temporal ---------------------------------------------------------------

# Temporal server gRPC address. In docker-compose this is temporal:7233.
TEMPORAL_ADDRESS=temporal:7233

# Temporal namespace (must match the server).
TEMPORAL_NAMESPACE=default

# --- Infisical (production secret store) ------------------------------------

INFISICAL_ADDR=https://app.infisical.com
INFISICAL_PROJECT_ID=<your-project-id>
INFISICAL_ENVIRONMENT=prod
INFISICAL_CLIENT_ID=<your-client-id>
INFISICAL_CLIENT_SECRET=<your-client-secret>

# --- Config polling ---------------------------------------------------------

# How often (in seconds) the config watcher re-fetches SMTP config.
CONFIG_POLL_INTERVAL=300

# --- Dev mode ---------------------------------------------------------------

# Set to "false" in production.
DEV_MODE=false
